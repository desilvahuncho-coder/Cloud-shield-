"use client";

import { useState, useEffect } from "react";
import { useRouter } from "next/navigation";
import { createClient } from "@/utils/supabase/client";

export default function TeamManagement() {
  const router = useRouter();
  const supabase = createClient();

  const [loading, setLoading] = useState(true);
  const [emailInput, setEmailInput] = useState("");
  const [teamMembers, setTeamMembers] = useState([]);
  const [invites, setInvites] = useState([]);
  const [generatedLink, setGeneratedLink] = useState("");
  const [actionLoading, setActionLoading] = useState(false);

  async function loadTeamData() {
    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        router.push("/login");
        return;
      }

      // Load user profile and team members matching their organization_id
      const { data: profile } = await supabase
        .from("users")
        .select("organization_id")
        .eq("id", session.user.id)
        .single();

      if (profile) {
        // Fetch active team members
        const { data: members } = await supabase
          .from("users")
          .select("id, email, created_at")
          .eq("organization_id", profile.organization_id);
        
        // Fetch pending invites
        const { data: activeInvites } = await supabase
          .from("organization_invites")
          .select("id, email, expires_at, token")
          .eq("organization_id", profile.organization_id)
          .gt("expires_at", new Date().toISOString());

        setTeamMembers(members || []);
        setInvites(activeInvites || []);
      }
    } catch (err) {
      console.error("Failed to compile team roster:", err);
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    loadTeamData();
  }, [router, supabase]);

  async function handleSendInvite(e) {
    e.preventDefault();
    if (!emailInput) return;
    setActionLoading(true);
    setGeneratedLink("");

    try {
      const res = await fetch("/api/team/invite", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: emailInput })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to generate invite token");

      setGeneratedLink(data.inviteLink);
      setEmailInput("");
      await loadTeamData(); // Refresh list

    } catch (err) {
      alert(err.message);
    } finally {
      setActionLoading(false);
    }
  }

  if (loading) {
    return (
      <div className="min-h-screen bg-slate-50 flex items-center justify-center text-slate-400 font-sans text-xs uppercase tracking-wider">
        Compiling team roster...
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans py-12 px-6">
      <div className="max-w-4xl mx-auto">
        
        <header className="mb-10 flex justify-between items-center border-b border-slate-200 pb-6">
          <div>
            <button onClick={() => router.push("/")} className="text-xs font-semibold text-indigo-600 hover:text-indigo-800 transition-colors mb-2 block">&larr; Return to Workspace</button>
            <h1 className="text-3xl font-extrabold text-slate-950 tracking-tight">Team Seats</h1>
          </div>
          <span className="bg-slate-200/60 text-slate-700 px-3 py-1 rounded text-xs font-semibold">
            {teamMembers.length} of 3 Seats Used
          </span>
        </header>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
          {/* LEFT: INVITE CONTROLLER */}
          <div className="md:col-span-1 space-y-6">
            <div className="bg-white p-6 border border-slate-200 rounded-lg shadow-sm">
              <h2 className="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Provision New Seat</h2>
              <form onSubmit={handleSendInvite} className="space-y-4">
                <div>
                  <label className="block text-[10px] uppercase tracking-wider text-slate-400 font-bold mb-1">Email Address</label>
                  <input
                    type="email"
                    required
                    value={emailInput}
                    onChange={(e) => setEmailInput(e.target.value)}
                    placeholder="teammate@company.com"
                    className="w-full border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-indigo-500 rounded p-2.5 text-sm outline-none transition-all"
                  />
                </div>
                <button
                  type="submit"
                  disabled={actionLoading || teamMembers.length >= 3}
                  className="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs uppercase tracking-wider rounded disabled:bg-slate-200 disabled:text-slate-400 transition-colors"
                >
                  {actionLoading ? "Generating Link..." : "Create Invite Link"}
                </button>
              </form>
            </div>

            {generatedLink && (
              <div className="bg-emerald-50 border border-emerald-100 p-4 rounded-lg">
                <h3 className="text-xs font-bold text-emerald-800 uppercase tracking-wider mb-2">Invite Token Ready</h3>
                <p className="text-[11px] text-emerald-700 leading-relaxed mb-3">Copy and send this registration URL to your teammate. It will expire in 48 hours.</p>
                <input
                  type="text"
                  readOnly
                  value={generatedLink}
                  onClick={(e) => e.target.select()}
                  className="w-full bg-white border border-emerald-200 rounded p-2 font-mono text-[10px] text-emerald-800 outline-none"
                />
              </div>
            )}
          </div>

          {/* RIGHT: ROSTER LISTS */}
          <div className="md:col-span-2 space-y-8">
            {/* ACTIVE SEATS */}
            <div className="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
              <h2 className="text-xs font-bold text-slate-400 uppercase tracking-widest p-6 border-b border-slate-100">Active Roster</h2>
              <div className="divide-y divide-slate-100">
                {teamMembers.map((member) => (
                  <div key={member.id} className="p-6 flex justify-between items-center">
                    <div>
                      <p className="text-sm font-bold text-slate-900">{member.email}</p>
                      <p className="text-[10px] text-slate-400 mt-0.5">Joined {new Date(member.created_at).toLocaleDateString()}</p>
                    </div>
                    <span className="text-[10px] uppercase font-bold text-slate-400 bg-slate-100 px-2 py-0.5 rounded">Active Seat</span>
                  </div>
                ))}
              </div>
            </div>

            {/* PENDING SEATS */}
            {invites.length > 0 && (
              <div className="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
                <h2 className="text-xs font-bold text-slate-400 uppercase tracking-widest p-6 border-b border-slate-100">Pending Invitations</h2>
                <div className="divide-y divide-slate-100">
                  {invites.map((invite) => (
                    <div key={invite.id} className="p-6 flex justify-between items-center">
                      <div>
                        <p className="text-sm font-bold text-slate-900">{invite.email}</p>
                        <p className="text-[10px] text-amber-500 mt-0.5">Expires {new Date(invite.expires_at).toLocaleDateString()}</p>
                      </div>
                      <button
                        onClick={() => {
                          const baseUrl = process.env.NEXT_PUBLIC_SITE_URL || "http://localhost:3000";
                          navigator.clipboard.writeText(`${baseUrl}/register?token=${invite.token}`);
                          alert("Invite URL copied to clipboard!");
                        }}
                        className="text-[10px] text-indigo-600 hover:text-indigo-800 font-bold uppercase tracking-wider"
                      >
                        Copy Link
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

      </div>
    </div>
  );
}
