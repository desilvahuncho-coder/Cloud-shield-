import { createClient } from "@/utils/supabase/server";
import { getTenantAwsCredentials } from "@/utils/aws/sts";
import { CostExplorerClient, GetCostAndUsageCommand } from "@aws-sdk/client-cost-explorer";
import { EC2Client, DescribeInstancesCommand } from "@aws-sdk/client-ec2";
import { CloudWatchClient, GetMetricDataCommand } from "@aws-sdk/client-cloudwatch";
import { NextResponse } from "next/server";

export async function GET() {
  const supabase = createClient();

  // 1. Authenticate the active user session
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    return NextResponse.json({ error: "Unauthorized session context" }, { status: 401 });
  }

  try {
    // 2. Fetch user's organization profile mapping
    const { data: profile } = await supabase
      .from("users")
      .select("organization_id")
      .eq("id", session.user.id)
      .single();

    if (!profile) throw new Error("Could not load organization mapping.");

    // 3. Resolve the organization's AWS credentials
    const { data: connection } = await supabase
      .from("aws_connections")
      .select("iam_role_arn, external_id")
      .eq("organization_id", profile.organization_id)
      .single();

    // If no AWS connection has been made yet, fallback gracefully to mock demo mode
    if (!connection) {
      return NextResponse.redirect(new URL("/api/feed/mock", request.url));
    }

    // 4. Negotiate temporary keys from AWS STS
    const credentials = await getTenantAwsCredentials(connection.iam_role_arn, connection.external_id);
    const region = process.env.AWS_REGION || "us-east-1";

    const ec2Client = new EC2Client({ region, credentials });
    const cloudwatchClient = new CloudWatchClient({ region, credentials });
    const ceClient = new CostExplorerClient({ region: "us-east-1", credentials }); // CE is us-east-1 only

    const today = new Date();
    const formattedToday = today.toISOString().split("T")[0];

    // --- DETECTION 1: TOP-LINE BILLING & SPIKE ANALYSIS ---
    const sevenDaysAgo = new Date();
    sevenDaysAgo.setDate(today.getDate() - 7);
    const formattedStart = sevenDaysAgo.toISOString().split("T")[0];

    const costCommand = new GetCostAndUsageCommand({
      TimePeriod: { Start: formattedStart, End: formattedToday },
      Granularity: "DAILY",
      Metrics: ["UnblendedCost"],
    });

    const costData = await ceClient.send(costCommand);
    const dailyCosts = costData.ResultsByTime?.map(r => parseFloat(r.Total?.UnblendedCost?.Amount || "0")) || [];
    
    // Calculate 7-day average and today's spend comparison
    const todaySpend = dailyCosts[dailyCosts.length - 1] || 0;
    const pastDays = dailyCosts.slice(0, -1);
    const avgHistoricalSpend = pastDays.length > 0 ? pastDays.reduce((a, b) => a + b, 0) / pastDays.length : todaySpend;

    let billingSpikeProblem = null;
    if (todaySpend > avgHistoricalSpend * 1.3) { // 30%+ increase triggers spike alarm
      const spikeAmount = todaySpend - avgHistoricalSpend;
      billingSpikeProblem = {
        id: `spike-billing-${formattedToday}`,
        type: "spike",
        title: "Your active cloud run rate jumped unexpectedly today",
        description: `Your cloud environment spent $${todaySpend.toFixed(2)} today compared to your rolling baseline of $${avgHistoricalSpend.toFixed(2)}/day. Action is required to shut down runaway test runs.`,
        risk: "red",
        structuralTarget: "AWS-Bill-Billing-Console",
        savings: parseFloat((spikeAmount * 30).toFixed(2)), // Projected monthly impact of unchecked spike
        createdAt: new Date().toISOString()
      };
    }

    // --- DETECTION 2: IDLE COMPUTE INSTANCES ---
    const ec2Command = new DescribeInstancesCommand({
      Filters: [{ Name: "instance-state-name", Values: ["running"] }]
    });

    const ec2Data = await ec2Client.send(ec2Command);
    const runningInstances = ec2Data.Reservations?.flatMap(r => r.Instances || []) || [];

    const idleInstanceProblems = [];

    // Evaluate utilization over the last 3 days for running instances
    if (runningInstances.length > 0) {
      const instanceIds = runningInstances.map(i => i.InstanceId);
      const threeDaysAgo = new Date();
      threeDaysAgo.setDate(today.getDate() - 3);

      const metricQueries = instanceIds.map((id, index) => ({
        Id: `m${index}`,
        MetricStat: {
          Metric: {
            Namespace: "AWS/EC2",
            MetricName: "CPUUtilization",
            Dimensions: [{ Name: "InstanceId", Value: id }]
          },
          Period: 86400, // 24-hour periods
          Stat: "Average"
        }
      }));

      const cwCommand = new GetMetricDataCommand({
        MetricDataQueries: metricQueries,
        StartTime: threeDaysAgo,
        EndTime: today
      });

      const metricResults = await cloudwatchClient.send(cwCommand);

      runningInstances.forEach((instance, index) => {
        const metricData = metricResults.MetricDataResults?.find(r => r.Id === `m${index}`);
        const avgCpuValues = metricData?.Values || [];
        
        // If CPU consistently under 2% across reporting periods, label as idle
        const isIdle = avgCpuValues.length > 0 && avgCpuValues.every(v => v < 2.0);

        if (isIdle) {
          const nameTag = instance.Tags?.find(t => t.Key === "Name")?.Value || instance.InstanceId;
          const instanceType = instance.InstanceType || "t3.medium";
          
          // Estimate savings based on baseline rates
          const estimatedHourlyCost = instanceType.startsWith("t") ? 0.04 : 0.12;
          const monthlySavings = parseFloat((estimatedHourlyCost * 24 * 30).toFixed(2));

          idleInstanceProblems.push({
            id: `idle-${instance.InstanceId}`,
            type: "idle",
            title: `Compute machine '${nameTag}' has been running idle for 3 days`,
            description: `This server is actively powered on but shows CPU utilization under 2%. Pausing this resource stops active billing leakage immediately without deleting data.`,
            risk: "amber",
            structuralTarget: instance.InstanceId,
            savings: monthlySavings,
            createdAt: new Date().toISOString()
          });
        });
      }
    }

    // Combine anomalies
    const allProblems = [];
    if (billingSpikeProblem) allProblems.push(billingSpikeProblem);
    allProblems.push(...idleInstanceProblems);

    // 5. SORTING ALGORITHM: Sort Red-risk (Spikes) first, then sort remaining by savings value
    const sortedProblems = allProblems.sort((a, b) => {
      if (a.risk === "red" && b.risk !== "red") return -1;
      if (a.risk !== "red" && b.risk === "red") return 1;
      return b.savings - a.savings;
    });

    // 6. TRUNCATION RULE: Bound the viewport to maximum 4 issues
    const finalQueue = sortedProblems.slice(0, 4);

    // Fetch total monthly savings tracking to return to top stats
    const { data: savingsLog } = await supabase
      .from("audit_logs")
      .select("savings_reclaimed")
      .eq("organization_id", profile.organization_id);

    const totalSavedThisMonth = savingsLog?.reduce((sum, log) => sum + parseFloat(log.savings_reclaimed || 0), 0) || 0.00;

    return NextResponse.json({
      metrics: {
        totalSavingsPotential: finalQueue.reduce((sum, p) => sum + p.savings, 0),
        activeAnomalies: finalQueue.length,
        totalSavedThisMonth
      },
      problems: finalQueue
    });

  } catch (err) {
    console.error("Telemetry Processing Error:", err);
    return NextResponse.json({ error: `Internal diagnostics failed: ${err.message}` }, { status: 500 });
  }
}
