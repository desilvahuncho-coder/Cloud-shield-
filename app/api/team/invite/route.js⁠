import { createClient } from "@/utils/supabase/server";
import { NextResponse } from "next/server";

export async function POST(request) {
  const supabase = createClient();

  // 1. Authenticate the active administrator making the invite
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    return NextResponse.json({ error: "Unauthorized session context" }, { status: 401 });
  }

  try {
    const { email: inviteeEmail } = await request.json();

    if (!inviteeEmail) {
      return NextResponse.json({ error: "Invitee email address is required." }, { status: 400 });
    }

    // 2. Fetch the admin's organization context
    const { data: adminProfile } = await supabase
      .from("users")
      .select("organization_id")
      .eq("id", session.user.id)
      .single();

    if (!adminProfile) {
      throw new Error("Could not load administrator organization context.");
    }

    // 3. Prevent duplicate invites for active seats
    const { data: existingUser } = await supabase
      .from("users")
      .select("id")
      .eq("email", inviteeEmail.trim().toLowerCase())
      .single();

    if (existingUser) {
      return NextResponse.json({ error: "This user is already registered in a seat." }, { status: 400 });
    }

    // 4. Generate a unique, secure invitation token
    const token = crypto.randomUUID();
    const expiresAt = new Date();
    expiresAt.setHours(expiresAt.getHours() + 48); // Tokens expire in 48 hours

    // 5. Save the pending invite record in Supabase
    const { error: inviteError } = await supabase
      .from("organization_invites")
      .insert({
        organization_id: adminProfile.organization_id,
        email: inviteeEmail.trim().toLowerCase(),
        token,
        expires_at: expiresAt.toISOString(),
        invited_by: session.user.id
      });

    if (inviteError) throw inviteError;

    // 6. Formulate the registration URL (your production domain or localhost)
    const baseUrl = process.env.NEXT_PUBLIC_SITE_URL || "http://localhost:3000";
    const inviteLink = `${baseUrl}/register?token=${token}`;

    // Note: In Week 2, this will trigger a real transactional email.
    // For our Week 1 checkpoint, we return the link directly for rapid testing.
    return NextResponse.json({
      success: true,
      message: "Invitation token registered successfully.",
      inviteLink
    });

  } catch (err) {
    console.error("Invitation Processing Error:", err);
    return NextResponse.json({ error: `Could not process invitation: ${err.message}` }, { status: 500 });
  }
}
