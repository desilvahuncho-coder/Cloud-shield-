import { NextResponse } from "next/server";
import { createRouteHandlerClient } from "@supabase/auth-helpers-nextjs";
import { cookies } from "next/headers";
import { EC2Client, StopInstancesCommand, DescribeInstancesCommand } from "@aws-sdk/client-ec2";
import { getAssumedCredentials } from "@/app/api/utils/aws-client";

/**
 * Handles the secure, server-side resolution of a flagged problem.
 * Re-validates user session, checks organization boundary, performs the 
 * action on AWS, and updates the immutable database audit trail.
 */
export async function POST(request) {
  const supabase = createRouteHandlerClient({ cookies });

  // 1. Authenticate the active user seat
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    return NextResponse.json({ error: "Session missing or expired" }, { status: 401 });
  }

  try {
    // Parse input safely
    const body = await request.json();
    const { resourceId, estimatedSavings, type } = body;

    if (!resourceId || !type) {
      return NextResponse.json({ error: "Missing required processing details" }, { status: 400 });
    }

    // 2. Fetch the specific user seat and resolve their Organization Context Boundary
    const { data: userProfile, error: userError } = await supabase
      .from("users")
      .select("organization_id, id")
      .eq("id", session.user.id)
      .single();

    if (userError || !userProfile) {
      return NextResponse.json({ error: "User seat profile mapping not found" }, { status: 403 });
    }

    // 3. Retrieve the shared AWS connection for this specific organization
    const { data: connection, error: connError } = await supabase
      .from("aws_connections")
      .select("iam_role_arn, external_id")
      .eq("organization_id", userProfile.organization_id)
      .single();

    if (connError || !connection) {
      return NextResponse.json({ error: "Cloud account connection link missing" }, { status: 404 });
    }

    // 4. Exchange credentials via server-side STS AssumeRole
    const temporaryCredentials = await getAssumedCredentials(
      connection.iam_role_arn,
      connection.external_id
    );

    const config = { region: "us-east-1", credentials: temporaryCredentials };
    const ec2Client = new EC2Client(config);

    // 5. Server-Side Re-Validation: Ensure the resource is real and actionable
    if (type === "idle") {
      try {
        const checkCommand = new DescribeInstancesCommand({ InstanceIds: [resourceId] });
        const checkData = await ec2Client.send(checkCommand);
        const currentState = checkData.Reservations?.[0]?.Instances?.[0]?.State?.Name;

        if (currentState !== "running") {
          return NextResponse.json({ error: "This server is already inactive or modifying status" }, { status: 400 });
        }
      } catch (awsErr) {
        console.error("AWS_REVALIDATION_FAILED:", awsErr);
        return NextResponse.json({ error: "Could not verify resource status on your cloud provider" }, { status: 404 });
      }

      // 6. Execute ACTION Policy (Strictly StopInstances only, no termination allowed)
      const stopCommand = new StopInstancesCommand({ InstanceIds: [resourceId] });
      await ec2Client.send(stopCommand);
    } else {
      // If it's a bill spike alert, resolving it just clears it from the feed view
      console.log(`Clearing generic budget alert anomaly: ${resourceId}`);
    }

    // 7. Write to immutable optimization audit table for exact seat attribution
    const { error: logError } = await supabase
      .from("optimization_audit_logs")
      .insert({
        organization_id: userProfile.organization_id,
        user_id: userProfile.id, // Explicitly attributes who pushed the button
        resource_id: resourceId,
        action_taken: type === "idle" ? "STOP_SERVER" : "DISMISS_BILL_SPIKE",
        estimated_savings: parseFloat(estimatedSavings || 0)
      });

    if (logError) {
      console.error("AUDIT_LOGGING_CRITICAL_FAULT:", logError);
      // We don't crash the response if the action succeeded but logging caught a hitch, 
      // but in production, you want this completely ironed out.
    }

    return NextResponse.json({ success: true, resolved: resourceId });

  } catch (error) {
    console.error("ACTION_EXECUTION_CRITICAL_FAULT:", error);
    return NextResponse.json({ error: "Internal structural processing failure during execution" }, { status: 500 });
  }
}
