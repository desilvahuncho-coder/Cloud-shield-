import { createClient } from "@/utils/supabase/server";
import { NextResponse } from "next/server";

export async function POST(request) {
  const supabase = createClient();

  try {
    const { userId, email, token, orgName } = await request.json();

    if (!userId || !email) {
      return NextResponse.json({ error: "Missing required registration parameters." }, { status: 400 });
    }

    // --- CASE A: REGISTERING VIA ACTIVE TEAM INVITATION ---
    if (token) {
      // 1. Fetch the invitation details securely on the server
      const { data: invite, error: inviteError } = await supabase
        .from("organization_invites")
        .select("organization_id, expires_at")
        .eq("token", token)
        .single();

      if (inviteError || !invite) {
        return NextResponse.json({ error: "Your invitation token is invalid." }, { status: 400 });
      }

      // 2. Validate token expiry
      if (new Date(invite.expires_at) < new Date()) {
        return NextResponse.json({ error: "Your invitation has expired." }, { status: 400 });
      }

      // 3. Map the new user to the existing organization
      const { error: userInsertError } = await supabase
        .from("users")
        .insert({
          id: userId,
          email: email.trim().toLowerCase(),
          organization_id: invite.organization_id
        });

      if (userInsertError) throw userInsertError;

      // 4. Burn the used token so it cannot be intercepted or reused
      const { error: deleteError } = await supabase
        .from("organization_invites")
        .delete()
        .eq("token", token);

      if (deleteError) {
        console.error("[WARNING] Failed to delete consumed token:", deleteError);
      }

      return NextResponse.json({ 
        success: true, 
        message: "Seat aligned to organization successfully." 
      });

    } 
    
    // --- CASE B: REGISTERING A BRAND NEW WORKSPACE ---
    else {
      if (!orgName) {
        return NextResponse.json({ error: "Organization name is required to start a new workspace." }, { status: 400 });
      }

      // 1. Insert the new organization profile
      const { data: newOrg, error: orgError } = await supabase
        .from("organizations")
        .insert({ name: orgName.trim() })
        .select("id")
        .single();

      if (orgError) throw orgError;

      // 2. Map the creator's user profile to the brand new organization
      const { error: userInsertError } = await supabase
        .from("users")
        .insert({
          id: userId,
          email: email.trim().toLowerCase(),
          organization_id: newOrg.id
        });

      if (userInsertError) throw userInsertError;

      return NextResponse.json({ 
        success: true, 
        message: "Organization workspace successfully provisioned." 
      });
    }

  } catch (err) {
    console.error("Intake Server Error:", err);
    return NextResponse.json({ 
      error: `Failed to complete workspace registration intake: ${err.message || "Database write failure"}` 
    }, { status: 500 });
  }
}
