"use client";

import { useState, useEffect } from "react";
import { useRouter } from "next/navigation";
import { createClient } from "@/utils/supabase/client";

export default function Dashboard() {
  const router = useRouter();
  const supabase = createClient();

  const [loading, setLoading] = useState(true);
  const [alerts, setAlerts] = useState([]);
  const [integration, setIntegration] = useState(null);
  const [userProfile, setUserProfile] = useState(null);
  
  // Rule #3 metrics
  const [metrics, setMetrics] = useState({
    currentMonthCost: 0.00,
    projectedMonthEnd: 0.00,
    totalSavings: 0.00
  });

  async function loadDashboardData() {
    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        router.push("/login");
        return;
      }

      // 1. Fetch User & Org Profile
      const { data: profile, error: profileErr } = await supabase
        .from("users")
        .select("email, organization_id, organizations(name)")
        .eq("id", session.user.id)
        .single();

      if (profileErr || !profile) throw new Error("Could not resolve profile details.");
      setUserProfile(profile);

      // 2. Fetch AWS Integration
      const { data: awsData } = await supabase
        .from("aws_integrations")
        .select("status, aws_account_id")
        .eq("organization_id", profile.organization_id)
        .maybeSingle();

      setIntegration(awsData);

      // 3. Fetch Priority-Sorted Alerts (Limit to exactly 4 items per Rule #3)
      const { data: alertData, error: alertErr } = await supabase
        .from("alerts")
        .select("*")
        .eq("organization_id", profile.organization_id)
        .eq("status", "open")
        .order("severity", { ascending: false }) // Critical first
        .order("created_at", { ascending: false })
        .limit(4);

      if (alertErr) throw alertErr;
      setAlerts(alertData || []);

      // 4. In a real environment, these are calculated from active database syncs.
      // Providing defaults/mock fallbacks aligned to live integration state:
      if (awsData?.status === "active") {
        setMetrics({
          currentMonthCost: 1420.50,
          projectedMonthEnd: 1850.00,
          totalSavings: 340.20
        });
      } else {
        setMetrics({
          currentMonthCost: 0.00,
          projectedMonthEnd: 0.00,
          totalSavings: 0.00
        });
      }

    } catch (err) {
      console.error("Dashboard Load Failure:", err);
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    loadDashboardData();
  }, [router, supabase]);

  async function resolveAlert(alertId) {
    try {
      const { error } = await supabase
        .from("alerts")
        .update({ status: "resolved", resolved_at: new Date().toISOString() })
        .eq("id", alertId);

      if (error) throw error;
      await loadDashboardData(); // Refresh clean loop feed
    } catch (err) {
      alert(`Error resolving alert: ${err.message}`);
    }
  }

  if (loading) {
    return (
      <div className="min-h-screen bg-slate-50 flex items-center justify-center text-slate-400 font-sans text-xs uppercase tracking-wider">
        Loading problem feed...
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans py-12 px-6">
      <div className="max-w-4xl mx-auto">
        
        {/* Simple Navigation Header */}
        <header className="mb-12 flex justify-between items-center">
          <div>
            <h1 className="text-xl font-bold text-slate-950 tracking-tight">
              {userProfile?.organizations?.name || "Workspace"}
            </h1>
            <p className="text-[11px] text-slate-400">Logged in as {userProfile?.email}</p>
          </div>
          <div className="flex gap-2">
            <button
              onClick={() => router.push("/integrations/aws")}
              className="px-3 py-1.5 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 font-bold text-[10px] uppercase tracking-wider rounded transition-colors"
            >
              AWS Role Setup
            </button>
            <button
              onClick={async () => {
                await supabase.auth.signOut();
                router.push("/login");
              }}
              className="px-3 py-1.5 bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold text-[10px] uppercase tracking-wider rounded transition-colors"
            >
              Log Out
            </button>
          </div>
        </header>

        {/* RULE #3: EXACTLY THREE JARGON-FREE NUMBERS */}
        <section className="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
          
          <div className="bg-white border border-slate-200 rounded p-6 shadow-sm">
            <span className="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1">
              Current Month Cost
            </span>
            <p className="text-4xl font-black text-slate-950">${metrics.currentMonthCost.toFixed(2)}</p>
          </div>

          <div className="bg-white border border-slate-200 rounded p-6 shadow-sm">
            <span className="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1">
              Predicted Month-End
            </span>
            <p className="text-4xl font-black text-indigo-600">${metrics.projectedMonthEnd.toFixed(2)}</p>
          </div>

          <div className="bg-white border border-slate-200 rounded p-6 shadow-sm">
            <span className="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1">
              Total Monthly Savings
            </span>
            <p className="text-4xl font-black text-emerald-600">${metrics.totalSavings.toFixed(2)}</p>
          </div>

        </section>

        {/* Cloud Connection Setup Warning Banner if Integration is missing */}
        {!integration && (
          <div className="mb-10 p-5 bg-amber-50 border border-amber-200 rounded-md flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div className="text-xs text-amber-800">
              <p className="font-bold">No cloud connection linked.</p>
              <p className="mt-0.5">Please link an AWS IAM role to start parsing cost events into your feed.</p>
            </div>
            <button
              onClick={() => router.push("/integrations/aws")}
              className="px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white font-bold text-[10px] uppercase tracking-wider rounded transition-colors shrink-0"
            >
              Configure Setup &rarr;
            </button>
          </div>
        )}

        {/* RULE #3: SINGLE-COLUMN, PRIORITY-SORTED FEED (MAX 4 ACTIVES) */}
        <section>
          <div className="flex justify-between items-center mb-6">
            <h2 className="text-xs font-bold text-slate-400 uppercase tracking-widest">Active Workspace Problems</h2>
            <span className="text-[10px] font-bold uppercase tracking-widest text-slate-400">Showing Max 4 Priority</span>
          </div>
          
          {alerts.length === 0 ? (
            <div className="bg-white border border-slate-200 rounded-lg p-12 text-center text-slate-400 text-xs">
              No active problems. Your infrastructure is healthy and within budget limits.
            </div>
          ) : (
            <div className="space-y-4">
              {alerts.map((alert) => (
                <div 
                  key={alert.id} 
                  className={`p-6 border rounded bg-white shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-l-4 ${
                    alert.severity === "critical" ? "border-l-red-500 border-slate-200" : "border-l-amber-500 border-slate-200"
                  }`}
                >
                  <div className="space-y-1 max-w-2xl text-xs">
                    <div className="flex items-center gap-2 mb-1.5">
                      <span className={`px-2 py-0.5 rounded-[4px] font-bold text-[8px] uppercase tracking-wider ${
                        alert.severity === "critical" ? "bg-red-50 text-red-700" : "bg-amber-50 text-amber-700"
                      }`}>
                        {alert.severity}
                      </span>
                      <span className="text-slate-400 text-[9px]">{new Date(alert.created_at).toLocaleDateString()}</span>
                    </div>
                    <h3 className="text-sm font-bold text-slate-950">{alert.title}</h3>
                    <p className="text-slate-500 leading-relaxed">{alert.description}</p>
                  </div>

                  <button
                    onClick={() => resolveAlert(alert.id)}
                    className="px-4 py-2.5 border border-slate-200 hover:bg-slate-50 text-slate-700 font-bold text-[10px] uppercase tracking-widest rounded transition-all shrink-0"
                  >
                    Acknowledge & Resolve
                  </button>
                </div>
              ))}
            </div>
          )}
        </section>

      </div>
    </div>
  );
}
