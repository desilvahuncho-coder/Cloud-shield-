import { createClient } from "@/utils/supabase/server";
import { NextResponse } from "next/server";

export async function POST(request) {
  const requestUrl = new URL(request.url);
  const formData = await request.formData();
  const email = formData.get("email");
  const password = formData.get("password");
  const action = formData.get("action"); // 'login' or 'signup'
  const orgName = formData.get("orgName");

  const supabase = createClient();

  // A. USER LOGIN FLOW
  if (action === "login") {
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    if (error) {
      return NextResponse.redirect(`${requestUrl.origin}/login?error=${encodeURIComponent(error.message)}`, { status: 303 });
    }
    return NextResponse.redirect(`${requestUrl.origin}/`, { status: 303 });
  }

  // B. ADMIN SIGNUP & ORG CREATION FLOW
  if (action === "signup") {
    if (!orgName || orgName.trim() === "") {
      return NextResponse.redirect(`${requestUrl.origin}/login?error=Organization+name+is+required`, { status: 303 });
    }

    // 1. Manually check if organization name is already registered to avoid dirty signups
    const { data: existingOrg } = await supabase
      .from("organizations")
      .select("id")
      .eq("name", orgName.trim())
      .maybeSingle();

    if (existingOrg) {
      return NextResponse.redirect(`${requestUrl.origin}/login?error=Organization+name+already+exists`, { status: 303 });
    }

    // 2. Provision the organization first
    const { data: newOrg, error: orgError } = await supabase
      .from("organizations")
      .insert({ name: orgName.trim() })
      .select()
      .single();

    if (orgError) {
      return NextResponse.redirect(`${requestUrl.origin}/login?error=${encodeURIComponent(orgError.message)}`, { status: 303 });
    }

    // 3. Register the user under Supabase auth and pass the new org ID metadata
    const { error: signUpError } = await supabase.auth.signUp({
      email,
      password,
      options: {
        data: {
          organization_id: newOrg.id,
          role: "admin",
        },
      },
    });

    if (signUpError) {
      // Clean up org if signup fails to avoid orphaned database entries
      await supabase.from("organizations").delete().eq("id", newOrg.id);
      return NextResponse.redirect(`${requestUrl.origin}/login?error=${encodeURIComponent(signUpError.message)}`, { status: 303 });
    }

    return NextResponse.redirect(`${requestUrl.origin}/login?message=Registration+successful.+Please+log+in.`, { status: 303 });
  }

  return NextResponse.json({ error: "Invalid Action Request" }, { status: 400 });
}
