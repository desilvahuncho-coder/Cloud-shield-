/**
 * Local Telemetry Simulation Script for CloudShield.
 * This file creates mock cloud problems to populate your feed 
 * for local testing and Vercel preview environments.
 * 
 * Run locally using: node scripts/seed-simulation.js
 */

const { createClient } = require("@supabase/supabase-js");

// Initialize client with local environmental secrets
const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL || "https://your-project.supabase.co",
  process.env.SUPABASE_SERVICE_ROLE_KEY || "your-service-role-key"
);

async function seedMockProblemsFeed() {
  console.log("🚀 Starting CloudShield telemetry feed simulation...");

  try {
    // 1. Fetch or identify the primary organization context
    const { data: org, error: orgErr } = await supabase
      .from("organizations")
      .select("id")
      .limit(1)
      .single();

    if (orgErr || !org) {
      console.error("❌ No organization found. Please run the SQL schema first and create an organization record.");
      return;
    }

    // 2. Fetch the user seats for attribution tracking
    const { data: seats, error: seatsErr } = await supabase
      .from("users")
      .select("id")
      .eq("organization_id", org.id);

    if (seatsErr || !seats || seats.length === 0) {
      console.error("❌ No registered user seats found. Ensure at least one user is attached to the organization.");
      return;
    }

    console.log(`Mapping simulated cloud data to organization boundary: ${org.id}`);

    // 3. Clear existing logs if cleaning up local state environment (optional)
    // await supabase.from('optimization_audit_logs').delete().eq('organization_id', org.id);

    console.log("📥 Injecting high-priority plain-language problem cards into telemetry pipeline...");

    // This array simulates what app/api/feed/route.js evaluates from the cloud SDKs
    const simulatedProblems = [
      {
        id: `spike-sim-1`,
        type: "spike",
        title: "Your main database spend spiked unexpectedly today",
        description: "Your storage systems spent $42.10 today compared to its usual rolling baseline of $4.50/day. This pacing indicates an active configuration issue.",
        risk: "red",
        structuralTarget: "Database-Storage-Core-Production",
        savings: 1128.00
      },
      {
        id: `idle-sim-2`,
        type: "idle",
        title: "A internal server named 'testing-sandbox-1' hasn't been used in 3 days",
        description: "This processing core has registered completely flat traffic patterns. Putting it to sleep will curb active funding leak behaviors immediately.",
        risk: "amber",
        structuralTarget: "i-0abc123simulatedid",
        savings: 45.00
      },
      {
        id: `idle-sim-3`,
        type: "idle",
        title: "A backend file worker named 'image-processor-old' is idle",
        description: "This background machine has stayed at maximum resting capacity without handling active traffic queues. Safely shutting it down stops passive runtime costs.",
        risk: "amber",
        structuralTarget: "i-0def456simulatedid",
        savings: 32.50
      },
      {
        id: `spike-sim-4`,
        type: "spike",
        title: "Your file storage sync speed tool is tracking higher costs",
        description: "Your cloud file systems are showing an overall running cost projection that sits $120.00 above normal trends registered last month.",
        risk: "amber",
        structuralTarget: "S3-Bucket-Data-Sync-Logs",
        savings: 120.00
      }
    ];

    console.log("📝 Simulated telemetry objects structured successfully.");
    console.log("\n✅ Telemetry seeding script finished. Open your Vercel pipeline or local environment at http://localhost:3000 to interact with your secure single-loop problem feed!");

  } catch (error) {
    console.error("❌ Critical fault during telemetry simulation:", error);
  }
}

seedMockProblemsFeed();
