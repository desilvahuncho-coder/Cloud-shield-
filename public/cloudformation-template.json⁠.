{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "CloudShield Cross-Account Access Role. Grants secure, read-only billing diagnostics and safe power-saving access.",
  "Parameters": {
    "CentralAccountId": {
      "Type": "String",
      "Default": "123456789012",
      "Description": "The central AWS Account ID of the CloudShield application."
    },
    "SecureExternalId": {
      "Type": "String",
      "Description": "The unique, randomized security handshake token generated by your CloudShield setup portal."
    }
  },
  "Resources": {
    "CloudShieldCrossAccountRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "CloudShieldCrossAccountAccess",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::Sub": "arn:aws:iam::${CentralAccountId}:root"
                }
              },
              "Action": "sts:AssumeRole",
              "Condition": {
                "StringEquals": {
                  "sts:ExternalId": {
                    "Ref": "SecureExternalId"
                  }
                }
              }
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "CloudShieldDiagnosticsAndMitigation",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "AllowCostAndBillingDiagnostics",
                  "Effect": "Allow",
                  "Action": [
                    "ce:GetCostAndUsage",
                    "ce:GetCostForecast",
                    "ce:GetAnomalies"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "AllowInstanceStateDiscovery",
                  "Effect": "Allow",
                  "Action": [
                    "ec2:DescribeInstances",
                    "ec2:DescribeInstanceStatus"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "AllowSafePowerSavingStateChanges",
                  "Effect": "Allow",
                  "Action": [
                    "ec2:StopInstances"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      }
    }
  },
  "Outputs": {
    "RoleARN": {
      "Description": "Copy this ARN and paste it into your CloudShield setup portal to complete the handshake.",
      "Value": {
        "Fn::GetAtt": [
          "CloudShieldCrossAccountRole",
          "Arn"
        ]
      }
    }
  }
}
