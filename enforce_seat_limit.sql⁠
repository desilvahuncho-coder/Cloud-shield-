-- Create a function to check active seats before allowing a new user signup
CREATE OR REPLACE FUNCTION check_organization_seat_limit()
RETURNS TRIGGER AS $$
DECLARE
  active_seats_count INT;
BEGIN
  -- Count how many users are currently registered under this organization
  SELECT COUNT(*) INTO active_seats_count 
  FROM users 
  WHERE organization_id = NEW.organization_id;

  -- If we already have 3 or more registered seats, block the insert
  IF active_seats_count >= 3 THEN
    RAISE EXCEPTION 'This pilot organization has reached its maximum limit of 3 user seats.';
  END IF;

  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Bind the function as a safe pre-insert check on the users table
CREATE OR REPLACE TRIGGER trg_limit_seats
BEFORE INSERT ON users
FOR EACH ROW
EXECUTE FUNCTION check_organization_seat_limit();
