import { createClient } from '@supabase/supabase-js';
import { STSClient, AssumeRoleCommand } from '@aws-sdk/client-sts';
import { EC2Client, StopInstancesCommand, DescribeInstancesCommand } from '@aws-sdk/client-ec2';

const supabaseAdmin = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL,
  process.env.SUPABASE_SERVICE_ROLE_KEY
);

/**
 * Validates state requirements and executes infrastructure optimization commands
 */
export async function POST(request) {
  try {
    const { userId, problemType, resourceId, estimatedSavings } = await request.json();

    // 1. Core input parameter validation
    if (!userId || !problemType || !resourceId) {
      return new Response(JSON.stringify({ error: 'Missing parameters required for execution.' }), { status: 400 });
    }

    // 2. Server-side session verification: Confirm user profile and retrieve organization mapping
    const { data: userProfile, error: profileErr } = await supabaseAdmin
      .from('users')
      .select('organization_id')
      .eq('id', userId)
      .single();

    if (profileErr || !userProfile) {
      return new Response(JSON.stringify({ error: 'Server authentication validation rejected.' }), { status: 403 });
    }

    const orgId = userProfile.organization_id;

    // 3. Fetch the shared organization cloud account connection details
    const { data: awsConn, error: connErr } = await supabaseAdmin
      .from('aws_connections')
      .select('aws_role_arn')
      .eq('organization_id', orgId)
      .single();

    if (connErr || !awsConn) {
      return new Response(JSON.stringify({ error: 'No cloud provider profile associated with this organization.' }), { status: 404 });
    }

    // 4. Request temporary session keys via AWS STS AssumeRole
    const stsClient = new STSClient({ region: 'us-east-1' });
    const assumeRoleCmd = new AssumeRoleCommand({
      RoleArn: awsConn.aws_role_arn,
      RoleSessionName: `CloudShieldExecution-${orgId}`,
      DurationSeconds: 900
    });

    const assumedRole = await stsClient.send(assumeRoleCmd);
    const credentials = assumedRole.Credentials;

    const awsCredentials = {
      accessKeyId: credentials.AccessKeyId,
      secretAccessKey: credentials.SecretAccessKey,
      sessionToken: credentials.SessionToken,
    };

    const ec2Client = new EC2Client({ region: 'us-east-1', credentials: awsCredentials });

    // 5. Destructive Action Rule: Server-side validation before execution
    if (problemType === 'idle_instance') {
      // Re-verify that the specified infrastructure asset still exists and is running
      const verifyCmd = new DescribeInstancesCommand({
        InstanceIds: [resourceId]
      });
      
      const statusCheck = await ec2Client.send(verifyCmd);
      const targetState = statusCheck.Reservations[0]?.Instances[0]?.State?.Name;

      if (targetState !== 'running') {
        return new Response(JSON.stringify({ error: 'Action aborted: The cloud system is no longer running.' }), { status: 400 });
      }

      // Execute the safe pause function using the AWS EC2 SDK
      const stopCmd = new StopInstancesCommand({
        InstanceIds: [resourceId]
      });
      await ec2Client.send(stopCmd);
    } else {
      // For anomalous budget spike warnings, execution registers local track updates
      // so your technician teams can investigate underlying code arrays manually
    }

    // 6. Log a detailed, unalterable item directly inside the historical audit table
    const { error: logErr } = await supabaseAdmin
      .from('audit_logs')
      .insert([
        {
          organization_id: orgId,
          user_id: userId,
          resource_id: resourceId,
          action_taken: problemType === 'idle_instance' ? 'paused' : 'dismissed',
          estimated_savings: parseFloat(estimatedSavings || 0)
        }
      ]);

    if (logErr) throw logErr;

    return new Response(JSON.stringify({ success: true }), { status: 200 });
  } catch (error) {
    return new Response(JSON.stringify({ error: `Execution failed: ${error.message}` }), { status: 500 });
  }
}
