import { createClient } from '@supabase/supabase-js';
import { STSClient, AssumeRoleCommand } from '@aws-sdk/client-sts';
import { CostExplorerClient, GetCostAndUsageCommand } from '@aws-sdk/client-cost-explorer';

const supabaseAdmin = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL,
  process.env.SUPABASE_SERVICE_ROLE_KEY
);

export async function POST(request) {
  try {
    const { userId } = await request.json();

    if (!userId) {
      return new Response(JSON.stringify({ error: 'Authentication required' }), { status: 401 });
    }

    // 1. Verify user exists and pull their organization ID mapping
    const { data: userProfile, error: profileErr } = await supabaseAdmin
      .from('users')
      .select('organization_id')
      .eq('id', userId)
      .single();

    if (profileErr || !userProfile) {
      return new Response(JSON.stringify({ error: 'Access denied' }), { status: 403 });
    }

    const orgId = userProfile.organization_id;

    // 2. Fetch the existing AWS connection configuration
    const { data: awsConn, error: connErr } = await supabaseAdmin
      .from('aws_connections')
      .select('aws_role_arn')
      .eq('organization_id', orgId)
      .single();

    if (connErr || !awsConn) {
      return new Response(JSON.stringify({ error: 'No cloud account connected yet.' }), { status: 404 });
    }

    // 3. Generate short-lived temporary access credentials via AWS STS
    const stsClient = new STSClient({ region: 'us-east-1' });
    const assumeRoleCmd = new AssumeRoleCommand({
      RoleArn: awsConn.aws_role_arn,
      RoleSessionName: `CloudShieldFeed-${orgId}`,
      DurationSeconds: 900
    });

    const assumedRole = await stsClient.send(assumeRoleCmd);
    const credentials = assumedRole.Credentials;

    // 4. Connect to Cost Explorer using the assumed credentials
    const ceClient = new CostExplorerClient({
      region: 'us-east-1',
      credentials: {
        accessKeyId: credentials.AccessKeyId,
        secretAccessKey: credentials.SecretAccessKey,
        sessionToken: credentials.SessionToken,
      },
    });

    // Handle standard calendar computations for date metrics
    const now = new Date();
    const currentYear = now.getUTCFullYear();
    const currentMonth = String(now.getUTCMonth() + 1).padStart(2, '0');
    
    const startStr = `${currentYear}-${currentMonth}-01`;
    const tomorrow = new Date();
    tomorrow.setUTCDate(tomorrow.getUTCDate() + 1);
    const endStr = tomorrow.toISOString().split('T')[0];

    const costCmd = new GetCostAndUsageCommand({
      TimePeriod: { Start: startStr, End: endStr },
      Granularity: 'MONTHLY',
      Metrics: ['UnblendedCost'],
    });

    const costData = await ceClient.send(costCmd);
    
    // Parse the current total cost returned
    const currentCost = parseFloat(
      costData.ResultsByTime[0]?.Total?.UnblendedCost?.Amount || 0
    );

    // 5. Calculate the forecast: (Current Cost / Days Elapsed) * Total Days in Month
    const daysInMonth = new Date(currentYear, now.getUTCMonth() + 1, 0).getDate();
    const daysElapsed = now.getUTCDate();
    const forecastCost = (currentCost / daysElapsed) * daysInMonth;

    // 6. Aggregate local database configurations to pull historical metrics
    const { data: logs, error: logsErr } = await supabaseAdmin
      .from('audit_logs')
      .select('estimated_savings')
      .eq('organization_id', orgId);

    if (logsErr) throw logsErr;

    const totalSaved = logs.reduce((sum, item) => sum + parseFloat(item.estimated_savings), 0);

    return new Response(
      JSON.stringify({
        currentCost: currentCost.toFixed(2),
        forecastCost: forecastCost.toFixed(2),
        totalSaved: totalSaved.toFixed(2),
      }),
      { status: 200 }
    );
  } catch (error) {
    return new Response(JSON.stringify({ error: error.message }), { status: 500 });
  }
}
