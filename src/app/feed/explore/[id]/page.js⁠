'use client';
import { useState, useEffect } from 'react';
import { useSearchParams, useRouter, useParams } from 'next/navigation';
import { supabase } from '../../../../lib/supabase';

export default function ExplanationPage() {
  const params = useParams();
  const searchParams = useSearchParams();
  const router = useRouter();
  
  const problemId = params.id;
  const problemType = searchParams.get('type');
  const resourceId = searchParams.get('res');

  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');
  const [details, setDetails] = useState(null);
  const [executing, setExecuting] = useState(false);

  useEffect(() => {
    const fetchSpecificProblemDetails = async () => {
      try {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          router.push('/login');
          return;
        }

        // Fetch freshly from the specific detection endpoints to avoid stale state
        const endpoint = problemType === 'idle_instance' 
          ? '/api/feed/idle-detection' 
          : '/api/feed/bill-spike';

        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: session.user.id })
        });

        if (!response.ok) throw new Error('Could not retrieve current data for this item.');

        const data = await response.json();
        const currentProblem = data.problems?.find(p => p.id === problemId);

        if (!currentProblem) {
          throw new Error('This issue has already been resolved or is no longer active.');
        }

        setDetails(currentProblem);
      } catch (err) {
        setError(err.message);
      } finally {
        setLoading(false);
      }
    };

    fetchSpecificProblemDetails();
  }, [problemId, problemType, router]);

  const handleConfirmAction = async () => {
    setExecuting(true);
    setError('');
    
    try {
      const { data: { session } } = await supabase.auth.getSession();
      
      // Call the execution engine (to be completely built out in Feature H)
      const response = await fetch('/api/feed/execute-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId: session.user.id,
          problemId: details.id,
          problemType: details.type,
          resourceId: details.resourceId || '',
          estimatedSavings: details.estimatedSavings || details.dollarDifference
        })
      });

      const result = await response.json();
      if (!response.ok) throw new Error(result.error || 'Failed to complete optimization request.');

      // Action succeeded, return instantly back to the updated dashboard stream
      router.push('/feed');
    } catch (err) {
      setError(err.message);
      setExecuting(false);
    }
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-white text-slate-500 p-12 max-w-2xl mx-auto">
        <p className="text-sm">Retrieving situational details...</p>
      </div>
    );
  }

  if (error) {
    return (
      <div className="min-h-screen bg-white text-slate-900 p-12 max-w-2xl mx-auto space-y-4">
        <div className="p-3 bg-red-50 text-red-600 rounded text-sm">{error}</div>
        <button onClick={() => router.push('/feed')} className="text-sm font-semibold text-slate-600 hover:underline">
          Return to problem feed
        </button>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-white text-slate-900 pt-20 pb-16 px-8 max-w-2xl mx-auto">
      <div className="space-y-10">
        
        {/* Section 1: What it is in plain English */}
        <div className="space-y-2">
          <span className="text-xs font-semibold tracking-wider text-slate-400 uppercase">Detected Situation</span>
          <h1 className="text-3xl font-bold tracking-tight">
            {details.type === 'idle_instance'
              ? `The virtual server named '${details.resourceName}' is sitting idle`
              : `Your daily billing parameters experienced an unexpected surge`}
          </h1>
        </div>

        {/* Section 2: Why it was flagged */}
        <div className="space-y-2">
          <span className="text-xs font-semibold tracking-wider text-slate-400 uppercase">Why we flagged this</span>
          <p className="text-base text-slate-600 leading-relaxed">
            {details.type === 'idle_instance'
              ? `Our system monitored this server for 3 complete days and noticed that your team has zero processing tasks passing through it. It is consuming budget despite doing no work.`
              : `Today's current cumulative operational expenditure outpaced your standard 7-day trailing spending average by more than double. This indicates a configuration error or runaway loop.`}
          </p>
        </div>

        {/* Section 3: Exact consequences of action */}
        <div className="space-y-2">
          <span className="text-xs font-semibold tracking-wider text-slate-400 uppercase">What happens when you confirm</span>
          <p className="text-base text-slate-600 leading-relaxed">
            {details.type === 'idle_instance'
              ? `This server will be safely paused. No data or storage files are altered, changed, or deleted. You can turn this server back on immediately at any point if your team requires it.`
              : `CloudShield will isolate the metrics for this spending wave. (For this validation round, actions for budget spikes are logged while your technicians inspect application deployment variables manually).`}
          </p>
        </div>

        {/* Section 4: Massive Flat Financial Summary Representation */}
        <div className="pt-4 border-t border-slate-100">
          <span className="text-xs font-semibold tracking-wider text-slate-400 uppercase">Estimated Monthly Reduction</span>
          <div className="text-6xl font-extrabold tracking-tight text-green-600 mt-2">
            ${details.type === 'idle_instance' ? details.estimatedSavings : details.dollarDifference}
            <span className="text-xl font-normal text-slate-400 tracking-normal ml-2">/ month saved</span>
          </div>
        </div>

        {/* Section 5: Unified Single Action Invocation Interface */}
        <div className="pt-6">
          <button
            onClick={handleConfirmAction}
            disabled={executing}
            className="w-full py-3.5 px-4 rounded-md shadow-sm text-base font-semibold text-white bg-slate-900 hover:bg-slate-800 disabled:bg-slate-400 transition-colors"
          >
            {executing 
              ? 'Executing optimization changes...' 
              : `Pause it and save $${details.type === 'idle_instance' ? details.estimatedSavings : details.dollarDifference}/mo`}
          </button>
        </div>

      </div>
    </div>
  );
}
